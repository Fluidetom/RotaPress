#. translators: Email reminder subject. {site}=site name, {title}=event title, {days}=number of days before the event. Keep placeholders unchanged.
#: includes/class-rotapress-reminders.php:35
msgid "[{site}] Reminder: \"{title}\" in {days} day(s)"
msgstr "[{site}] Rappel : « {title} » dans {days} jour(s)"

#. translators: Email reminder body. Placeholders — {assignee}: user display name, {days}: days before the event, {title}: event title, {date}: event date (YYYY-MM-DD), {notes}: event notes, {site}: site name, {calendar_url}: calendar URL, {no_reminder_url}: opt-out URL. Keep all placeholder names unchanged.
#: includes/class-rotapress-reminders.php:43
msgid ""
"Hello {assignee},\n"
"\n"
"This is a reminder that you have an event in {days} day(s):\n"
"\n"
"Title: {title}\n"
"Date: {date}\n"
"Notes: {notes}\n"
"\n"
"View the calendar: {calendar_url}\n"
"\n"
"To stop reminders for this event: {no_reminder_url}\n"
"\n"
"—\n"
"{site}"
msgstr ""
"Bonjour {assignee},\n"
"\n"
"Ce message est un rappel que vous avez un événement dans {days} jour(s) :\n"
"\n"
"Titre : {title}\n"
"Date : {date}\n"
"Notes : {notes}\n"
"\n"
"Voir le calendrier : {calendar_url}\n"
"\n"
"Pour ne plus recevoir de rappels pour cet événement : {no_reminder_url}\n"
"\n"
"—\n"
"{site}"

